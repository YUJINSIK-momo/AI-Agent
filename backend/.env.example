PORT=4000
GITHUB_TOKEN=your_github_personal_access_token_here
CLAUDE_API_KEY=sk-ant-...

# Postgres 연결 문자열 (Supabase Dashboard → Database → URI)
SUPABASE_URL=postgresql://user:password@host:6543/postgres

# CORS 허용 origins (쉼표로 여러 개 가능)
# 예: http://localhost:5173,https://yourname.github.io
CORS_ORIGIN=http://localhost:5173
